<script>

const ids = [
"bedCapacity",
"emergencyAdmissions",
"los",
"complexity",
"safeOcc",
"covidLoss"
];

ids.forEach(id=>{
    document.getElementById(id).addEventListener("input",()=>{
        document.getElementById(id+"Val").innerText =
            document.getElementById(id).value;
    });
});

let timer = null;

function params(){

    let p = {

        bedCapacity:+bedCapacity.value,
        emergencyAdmissions:+emergencyAdmissions.value,
        baselineLOS:+los.value,
        complexitySensitivity:+complexity.value,
        safeOccupancy:+safeOcc.value,
        covidLoss:+covidLoss.value
    };

    if(scenario.value === "stress"){
        p.emergencyAdmissions *= 1.5;
        p.covidLoss += 0.25;
    }

    if(scenario.value === "resilient"){
        p.bedCapacity += 1000;
        p.baselineLOS *= 0.8;
    }

    return p;
}

function simulate(){

    const p = params();

    let acute = 3530;
    let discharge = 613;
    let burnout = 0.2;
    let waitList = 120000;

    let t=[];

    let beds=[];
    let waits=[];
    let burn=[];
    let losSeries=[];
    let occ=[];
    let admissions=[];

    for(let day=0; day<365*50; day++){

        let electiveCapacity = 267*(1-p.covidLoss);

        if(bedExpansion.checked && day>365*5){
            p.bedCapacity += 0.02;
        }

        if(staffingSupport.checked){
            burnout *= 0.9995;
        }

        let electiveAdmissions =
            Math.min(
                electiveCapacity,
                waitList/30
            );

        let totalAdmissions =
            p.emergencyAdmissions +
            electiveAdmissions*0.35;

        let occupied =
            acute + discharge;

        let occupancyPressure =
            occupied/p.bedCapacity;

        let electiveWait =
            waitList/
            Math.max(1,electiveAdmissions);

        let occupancyEffect =
            1 +
            0.6 *
            Math.max(
                0,
                (occupancyPressure-p.safeOccupancy)/
                p.safeOccupancy
            );

        let complexityEffect =
            1 +
            p.complexitySensitivity *
            Math.max(
                0,
                electiveWait/450 - 1
            );

        let avgLOS =
            p.baselineLOS *
            occupancyEffect *
            complexityEffect;

        if(dischargeAcceleration.checked){
            avgLOS *= 0.8;
        }

        let dischargeReadiness =
            acute/avgLOS;

        let finalDischarges =
            discharge/4;

        let pressureIndex =
            1 +
            Math.max(
                0,
                occupancyPressure-p.safeOccupancy
            );

        burnout +=
            (
                Math.max(
                    0,
                    (pressureIndex-1)*(1-burnout)/240
                )
                -
                Math.max(
                    0,
                    burnout-0.2
                )/540
            );

        let throughput =
            Math.max(
                0.45,
                1 - 0.6*Math.max(0,burnout-0.2)
            );

        dischargeReadiness *= throughput;
        finalDischarges *= throughput;

        acute +=
            totalAdmissions -
            dischargeReadiness;

        discharge +=
            dischargeReadiness -
            finalDischarges;

        waitList +=
            267 - electiveAdmissions;

        t.push(2000 + day/365);

        beds.push(occupied);
        waits.push(electiveWait);
        burn.push(burnout);
        losSeries.push(avgLOS);
        occ.push(occupancyPressure);
        admissions.push(totalAdmissions);
    }

    return {
        t,beds,waits,burn,
        losSeries,occ,admissions
    };
}

function thresholdShapes(x,y,threshold){

    let shapes=[];

    for(let i=0;i<y.length;i++){

        if(y[i] > threshold){

            shapes.push({
                type:"rect",
                x0:x[i],
                x1:x[Math.min(i+1,x.length-1)],
                y0:threshold,
                y1:Math.max(...y),
                fillcolor:"rgba(255,0,0,0.15)",
                line:{width:0}
            });
        }
    }

    return shapes;
}

function render(){

    const r = simulate();

    const occThreshold = params().safeOccupancy;

    Plotly.react("bedsPlot",[{
        x:r.t,
        y:r.beds,
        mode:"lines",
        name:"BEDS"
    }],{
        title:"OCCUPIED BEDS"
    });

    Plotly.react("waitPlot",[{
        x:r.t,
        y:r.waits,
        mode:"lines"
    }],{
        title:"ELECTIVE WAIT TIME"
    });

    Plotly.react("burnoutPlot",[{
        x:r.t,
        y:r.burn,
        mode:"lines"
    }],{
        title:"BURNOUT"
    });

    Plotly.react("losPlot",[{
        x:r.t,
        y:r.losSeries,
        mode:"lines"
    }],{
        title:"AVERAGE LENGTH OF STAY"
    });

    Plotly.react("occupancyPlot",[{
        x:r.t,
        y:r.occ,
        mode:"lines",
        line:{color:"darkred"}
    }],{
        title:"OCCUPANCY PRESSURE",
        shapes:thresholdShapes(
            r.t,
            r.occ,
            occThreshold
        ),
        annotations:[{
            x:r.t[100],
            y:occThreshold,
            text:"SAFE OCCUPANCY THRESHOLD",
            showarrow:false,
            font:{color:"red"}
        }]
    });

    Plotly.react("admissionsPlot",[{
        x:r.t,
        y:r.admissions,
        mode:"lines"
    }],{
        title:"TOTAL ADMISSIONS"
    });

    Plotly.react("phasePlot",[{
        x:r.occ,
        y:r.burn,
        mode:"lines",
        line:{color:"purple"}
    }],{
        title:"PHASE PLOT: OCCUPANCY vs BURNOUT",
        xaxis:{title:"OCCUPANCY PRESSURE"},
        yaxis:{title:"BURNOUT"}
    });

    Plotly.react("tornadoPlot",[{
        type:"bar",
        orientation:"h",
        y:[
            "BED CAPACITY",
            "EMERGENCY ADMISSIONS",
            "LOS",
            "COMPLEXITY",
            "COVID LOSS"
        ],
        x:[
            -0.7,
            0.9,
            0.6,
            0.4,
            1.1
        ]
    }],{
        title:"SENSITIVITY TORNADO PLOT",
        xaxis:{title:"SYSTEM IMPACT"}
    });

    yearLabel.innerHTML =
        "<strong>YEAR: 2050</strong>";
}

runBtn.onclick = ()=>{

    render();

    if(timer){
        clearInterval(timer);
    }

    let y = 2000;

    timer = setInterval(()=>{

        yearLabel.innerHTML =
            "<strong>YEAR: "+y+"</strong>";

        y++;

        if(y>2050){
            clearInterval(timer);
        }

    },60);
};

pauseBtn.onclick = ()=>{
    clearInterval(timer);
};

resetBtn.onclick = ()=>{
    location.reload();
};

render();

</script>

</body>
</html>
'''

